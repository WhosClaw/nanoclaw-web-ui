# NanoClaw Web UI — Environment Variable Reference
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Server binding ──────────────────────────────────────────────────────────
# Port the server listens on (default: 3000)
WEB_UI_PORT=3000

# Host to bind to.
# IMPORTANT: When running inside Docker, this MUST be 0.0.0.0.
# For local (non-Docker) use, keep as localhost for security.
WEB_UI_HOST=localhost

# ── Authentication ───────────────────────────────────────────────────────────
# Optional. When set, clients must send this token to authenticate.
# Leave blank to disable authentication (not recommended in production).
WEB_UI_AUTH_TOKEN=

# ── Customization ────────────────────────────────────────────────────────────
# Name displayed in the Web UI header and assistant messages (default: NanoClaw)
ASSISTANT_NAME=NanoClaw

# ── Static files ─────────────────────────────────────────────────────────────
# Absolute path to the static files directory.
# Default (non-Docker): resolved automatically relative to dist/
# Docker: set to /app/public (handled by the Dockerfile ENV directive)
STATIC_PATH=

# ── Debugging ────────────────────────────────────────────────────────────────
# Set to any truthy value to enable debug log output
DEBUG=
